{
  "expo": {
    "name": "NOVA Driver",
    "slug": "nova-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/novaLogo.png",
    "splash": {
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "NSLocationWhenInUseUsageDescription": "NOVA needs your location to share live bus position with passengers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "NOVA needs your location in the background so passengers can track the bus even when you lock your screen.",
        "NSLocationAlwaysUsageDescription": "NOVA needs always-on location access during trips."
      }
    },
    "android": {
      "icon": "./assets/novaLogo.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/novaLogo.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.sahilsunar.novadriver"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow NOVA to use your location during trips.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5d49b5a4-467a-4776-83b4-6a14d8799f39"
      }
    }
  }
}
